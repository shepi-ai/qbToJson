# qbToJson Service Configuration

# Supabase (direct PostgREST access via supabase-py)
SUPABASE_URL=https://mdgmessqbfebrbvjtndz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Inbound API key — used by api_server.py to authenticate incoming requests
# and by account_lookup_client.py for its outbound lookup endpoint.
# Not related to Supabase. Generate with: openssl rand -base64 32
QBTOJSON_API_KEY=your-api-key-here

# API Server Configuration
PORT=5000

# Optional: Logging Configuration
LOG_LEVEL=INFO    # DEBUG, INFO, WARNING, ERROR
